# LLM Provider: "openai" o "anthropic"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# LLM Parameters
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Docker
ATTACKER_CONTAINER=attacker
TARGET_IP=10.10.0.10
ATTACKER_IP=10.10.0.5

# Loki
LOKI_URL=http://localhost:3100
