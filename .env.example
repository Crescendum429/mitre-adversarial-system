# Proveedor del agente ATACANTE. Uno de: openai, anthropic, google, groq, openrouter, cerebras
LLM_PROVIDER=openai

# OpenAI (paid)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# Anthropic (paid)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Google Gemini (free tier amplio)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# Groq (free tier con Llama 3.3 70B muy rapido)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (free tier con varios modelos open-weight)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Cerebras (free tier con Qwen 3 235B)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# Proveedor del agente OBSERVADOR. Puede ser distinto al del atacante.
# Vacio para usar el mismo proveedor/modelo que el atacante.
OBSERVER_PROVIDER=
OBSERVER_MODEL=

# Reproducibilidad (critico para tesis academica)
LLM_SEED=42
# Temperatura separada por rol: atacante con exploracion ligera, observador determinista
ATTACKER_TEMPERATURE=0.2
OBSERVER_TEMPERATURE=0.0
# Compatibilidad con .env anteriores (se usa si las dos anteriores no estan)
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# Docker
ATTACKER_CONTAINER=attacker
TARGET_IP=10.10.0.10
ATTACKER_IP=10.10.0.5

# Loki
LOKI_URL=http://localhost:3100

# Opcional: override del path de memoria (default: data/attack_playbooks.json)
# MITRE_MEMORY_FILE=/path/custom/playbooks.json

# Grafana (visualizacion auxiliar del lab; modelo de amenaza local)
GRAFANA_ADMIN_PASSWORD=changeme-strong-password
GRAFANA_ANONYMOUS=false
